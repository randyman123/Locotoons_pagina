{
  "name": "locotoons-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend NestJS para ecommerce Locotoons",
  "scripts": {
    "start": "nest start",
    "start:dev": "ts-node-dev --poll --transpile-only --ignore-watch node_modules --respawn src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint '{src,test}/**/*.{ts,js}' --fix",
    "users:make-admin": "ts-node src/scripts/make-admin.ts",
    "categories:sync": "ts-node src/scripts/sync-official-categories.ts",
    "products:sync": "ts-node src/scripts/sync-seed-products.ts",
    "catalog:prepare": "ts-node src/scripts/prepare-initial-catalog.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.3.0",
    "@nestjs/typeorm": "^11.0.1",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.0",
    "mysql2": "^3.3.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.0",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^5.0.0",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.18"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.0.10",
    "@types/bcryptjs": "^2.4.2",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.3",
    "@types/node": "^20.11.0",
    "@types/passport-jwt": "^3.0.8",
    "@types/passport-local": "^1.0.34",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.1",
    "jest": "^29.6.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.0"
  }
}
